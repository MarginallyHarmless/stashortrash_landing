<section class="fade-in py-20 md:py-32 px-4 relative overflow-hidden section-slant-down bg-carbon-light/30">
  <!-- Larger teal glow behind stat -->
  <div class="glow-teal top-[40%] left-[50%] -translate-x-1/2"></div>

  <div class="relative z-10 max-w-3xl mx-auto text-center">
    <!-- Teal accent bar above heading -->
    <div class="w-15 h-1 bg-teal mx-auto mb-8 rounded-full"></div>

    <h2 class="text-3xl md:text-5xl font-bold mb-8">
      Thousands of Photos. No Time to Sort Them.
    </h2>
    <p class="text-white/60 text-lg max-w-xl mx-auto">
      Photos pile up — duplicates, blurry shots, random screenshots you forgot about. You know you should clean up, but <span class="text-white/90 font-medium">where do you even start?</span>
    </p>

    <!-- Escalating stats -->
    <div class="mt-12 space-y-10" id="stat-escalation">
      <div class="opacity-0 translate-y-5 transition-all duration-500" data-stat="0">
        <div class="text-3xl md:text-5xl font-extrabold text-white/60" data-count="250" data-suffix="">0</div>
        <p class="text-white/40 text-sm mt-1">screenshots you forgot about</p>
      </div>
      <div class="opacity-0 translate-y-5 transition-all duration-500" data-stat="1">
        <div class="text-4xl md:text-6xl font-extrabold text-white/60" data-count="400" data-suffix="">0</div>
        <p class="text-white/40 text-sm mt-1">duplicates taking up space</p>
      </div>
      <div class="opacity-0 scale-90 transition-all duration-500" data-stat="2">
        <div class="inline-block rounded-full bg-teal/15 px-8 py-4">
          <div class="text-6xl md:text-8xl font-extrabold text-teal-bright glow-text-teal" data-count="3000" data-suffix="+">0+</div>
        </div>
        <p class="text-white/50 mt-2">photos on the average phone</p>
      </div>
    </div>
  </div>
</section>

<script>
  const escalation = document.getElementById('stat-escalation');
  if (escalation) {
    let started = false;
    const stats = escalation.querySelectorAll<HTMLElement>('[data-stat]');
    const glowOrb = escalation.closest('section')?.querySelector('.glow-teal') as HTMLElement | null;

    const countUp = (el: HTMLElement, target: number, suffix: string, duration: number) => {
      const start = performance.now();
      const step = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target).toLocaleString() + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    const reveal = (stat: HTMLElement, delay: number) => {
      setTimeout(() => {
        stat.style.opacity = '1';
        stat.style.transform = 'translateY(0) scale(1)';
        const numEl = stat.querySelector<HTMLElement>('[data-count]');
        if (numEl) {
          const target = Number(numEl.dataset.count);
          const suffix = numEl.dataset.suffix || '';
          const duration = target > 1000 ? 1200 : target > 200 ? 600 : 400;
          countUp(numEl, target, suffix, duration);
        }
      }, delay);
    };

    // Glow pulse when the big number lands
    const pulseGlow = () => {
      if (!glowOrb) return;
      glowOrb.style.transition = 'opacity 0.3s ease-out';
      glowOrb.style.opacity = '0.5';
      setTimeout(() => {
        glowOrb.style.transition = 'opacity 0.8s ease-out';
        glowOrb.style.opacity = '0.2';
      }, 400);
    };

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !started) {
        started = true;
        reveal(stats[0], 0);
        reveal(stats[1], 500);
        setTimeout(() => {
          reveal(stats[2], 0);
          // Pulse glow when big count finishes
          setTimeout(pulseGlow, 1200);
        }, 1000);
      }
    }, { threshold: 0.3 });

    observer.observe(escalation);
  }
</script>
