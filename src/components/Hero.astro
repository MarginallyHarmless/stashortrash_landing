---
import SplineScene from './SplineScene.tsx';
---

<section class="relative min-h-screen overflow-hidden flex flex-col pt-16">
  <!-- Glow orbs -->
  <div class="glow-teal top-[-100px] right-[-100px] z-0"></div>
  <div class="glow-mauve bottom-[10%] left-[-150px] z-0"></div>

  <!-- Spline scene — oversized on mobile so canvas renders wider FOV, scaled back to fit -->
  <div id="spline-wrapper" aria-hidden="true" class="absolute z-20 origin-center
    w-[175%] h-[175%] -top-[42%] -left-[37.5%] scale-[0.52]
    sm:w-[150%] sm:h-[150%] sm:-top-[30%] sm:-left-[25%] sm:scale-[0.6]
    md:w-[120%] md:h-[120%] md:-top-[20%] md:-left-[10%] md:scale-[0.9]">
    <SplineScene client:visible scene="https://prod.spline.design/Cfm4i5957ArEJqgM/scene.splinecode?v=2" className="h-full" />
  </div>

  <!-- Gradient scrim overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-carbon/90 via-carbon/30 to-transparent z-30 pointer-events-none"></div>

  <!-- Text content pinned to bottom -->
  <div class="relative z-40 mt-auto px-4 pointer-events-none">
    <div class="max-w-4xl lg:max-w-5xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-6">
        Gallery Cleanup That Actually Feels Good
      </h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-8">
        Every photo, full-screen. Swipe left to trash, right to keep. Clean your entire gallery in minutes, not hours.
      </p>
      <a
        href="https://play.google.com/store/apps/details?id=YOUR_APP_ID"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block transition-transform hover:scale-105 pointer-events-auto"
      >
        <img
          src="/images/google-play-badge.png"
          alt="Get Stash or Trash on Google Play — free photo cleanup app"
          width="250"
          height="75"
          class="h-[4.5rem] w-auto"
        />
      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="relative z-40 pt-6 pb-6 flex justify-center pointer-events-none">
    <div class="scroll-hint text-white/40">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<script>
  function disableSplineScroll() {
    const wrapper = document.getElementById('spline-wrapper');
    if (!wrapper) return;

    const handler = (e: WheelEvent) => {
      e.stopPropagation();
      e.preventDefault();
      window.scrollBy({ top: e.deltaY, behavior: 'instant' });
    };

    // Capture phase on wrapper to intercept before Spline's canvas listener
    wrapper.addEventListener('wheel', handler, { passive: false, capture: true });

    // Also observe for the canvas appearing and attach directly to it
    const observer = new MutationObserver(() => {
      const canvas = wrapper.querySelector('canvas');
      if (canvas) {
        canvas.addEventListener('wheel', handler, { passive: false, capture: true });
        observer.disconnect();
      }
    });
    observer.observe(wrapper, { childList: true, subtree: true });

    // Check if canvas already exists
    const existing = wrapper.querySelector('canvas');
    if (existing) {
      existing.addEventListener('wheel', handler, { passive: false, capture: true });
      observer.disconnect();
    }
  }

  disableSplineScroll();
</script>
